# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Get a free DB at: https://neon.tech  or  https://supabase.com
DATABASE_URL="postgresql://user:password@host:5432/poetryhub?sslmode=require"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="change-me-to-a-long-random-string"

# Initial admin credentials (used by seed script, change after first login)
ADMIN_EMAIL="admin@poetryhub.com"
ADMIN_PASSWORD="change-me-in-production"

# ── App ───────────────────────────────────────────────────────────────────────
NUXT_PUBLIC_APP_URL="https://your-app.vercel.app"

# ── Google sign-in (OAuth 2.0 “Web application” client) ───────────────────────
# The login/signup pages only show “Continue with Google” when BOTH values below
# are non-empty (see GET /api/auth/google-config).
#
# 1. Google Cloud Console → APIs & Services → Credentials → Create OAuth client ID (Web).
# 2. Authorized redirect URIs (exact):
#      http://localhost:3000/api/auth/google/callback
#      https://<your-production-domain>/api/auth/google/callback
# 3. Copy Client ID and Client secret into .env (or Vercel env vars).
#
# Server-only secret + client ID:
NUXT_OAUTH_GOOGLE_CLIENT_ID=""
NUXT_OAUTH_GOOGLE_CLIENT_SECRET=""
#
# Optional duplicate of the same Client ID — use on Vercel if the button did not
# appear without rebuilding (NUXT_PUBLIC_* is available to the browser bundle):
# NUXT_PUBLIC_OAUTH_GOOGLE_CLIENT_ID=""
#
# Apply DB changes for Google (nullable passwordHash, googleId): npx prisma migrate deploy
# or: npx prisma db push

# Optional: email allowed to save Instagram carousel site defaults (theme, typography). Defaults to vasileeduardbogdan@gmail.com
# NUXT_PUBLIC_CAROUSEL_DEFAULTS_ADMIN_EMAIL="you@example.com"

# ── External APIs ─────────────────────────────────────────────────────────────
# PoetryDB is free and requires no API key
POETRY_DB_URL="https://poetrydb.org"

# Optional: poem detail page can infer written year/period via Wikipedia; Anthropic fills gaps when set
# ANTHROPIC_API_KEY=""
