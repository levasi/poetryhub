# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Get a free DB at: https://neon.tech  or  https://supabase.com
DATABASE_URL="postgresql://user:password@host:5432/poetryhub?sslmode=require"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="change-me-to-a-long-random-string"

# Initial admin credentials (used by seed script, change after first login)
ADMIN_EMAIL="admin@poetryhub.com"
ADMIN_PASSWORD="change-me-in-production"

# ── App ───────────────────────────────────────────────────────────────────────
NUXT_PUBLIC_APP_URL="https://your-app.vercel.app"

# ── External APIs ─────────────────────────────────────────────────────────────
# PoetryDB is free and requires no API key
POETRY_DB_URL="https://poetrydb.org"
