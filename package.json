{
  "name": "poetryhub",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "imports": {
    "#internal/nuxt/paths": "./nuxt-internal-paths.mjs"
  },
  "scripts": {
    "build": "prisma generate && nuxt build",
    "dev": "nuxt dev",
    "dev:mem": "NODE_OPTIONS='--max-old-space-size=8192' nuxt dev",
    "dev:tools": "NUXT_DEVTOOLS=true nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare && node scripts/patch-nitropack-node-imports.mjs",
    "vercel:link": "bash scripts/vercel-cli.sh link",
    "env:pull:prod": "bash scripts/vercel-cli.sh env pull .env.local --environment=production --yes",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx scripts/seed.ts",
    "db:prune-non-ro": "tsx scripts/delete-non-romanian-poems.ts",
    "db:ro-diacritics": "tsx scripts/add-ro-diacritics.ts",
    "db:studio": "prisma studio",
    "write:lexicon": "tsx scripts/import-write-lexicon.ts",
    "write:dom-definitions": "tsx scripts/apply-dom-definitions.ts",
    "write:dex": "tsx scripts/import-dex-definitions.ts",
    "write:lexicon:from-sqlite": "tsx scripts/import-lexicon-from-sqlite.ts",
    "poems:import": "tsx scripts/import-poems.ts",
    "poems:import-ro": "tsx scripts/import-romanianvoice.ts",
    "poems:import-ro-full": "tsx scripts/import-romanianvoice.ts --romanian-only",
    "poems:import-alecsandri-ws": "tsx scripts/import-alecsandri-wikisource.ts",
    "authors:portraits": "tsx scripts/backfill-author-portraits.ts",
    "db:fix-nationality-roman": "tsx scripts/fix-authors-nationality-roman.ts",
    "authors:life-years": "tsx scripts/fetch-author-life-years-wikidata.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@iconify/vue": "^5.0.0",
    "@nuxtjs/i18n": "^10.2.4",
    "@nuxtjs/tailwindcss": "^6.12.1",
    "@pinia/nuxt": "^0.11.0",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "fuse.js": "^7.1.0",
    "html2canvas": "^1.4.1",
    "jose": "^5.9.6",
    "js-romanian-diacritics": "^1.0.1",
    "jszip": "^3.10.1",
    "nuxt": "^3.14.0",
    "pdf-parse": "^2.4.5",
    "pinia": "^3.0.0",
    "vue": "^3.5.13",
    "vue-router": "^4.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@iconify-json/heroicons": "^1.2.3",
    "@types/bcryptjs": "^2.4.6",
    "@types/google.maps": "^3.58.1",
    "@types/jszip": "^3.4.0",
    "@types/node": "^22.9.0",
    "better-sqlite3": "^11.7.0",
    "dotenv": "^16.4.5",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
