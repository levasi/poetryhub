// Prisma schema for PoetryHub
// Supports PostgreSQL (Neon, Supabase, or any PG provider)

generator client {
  provider      = "prisma-client-js"
  // Vercel / AWS Lambda (Amazon Linux) — required for Prisma engines in production
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Authors ────────────────────────────────────────────────────────────────

model Author {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  bio         String?  @db.Text
  birthYear   Int?
  deathYear   Int?
  nationality String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  poems Poem[]

  @@index([slug])
}

// ─── Tags ────────────────────────────────────────────────────────────────────

model Tag {
  id       String  @id @default(cuid())
  name     String  @unique
  slug     String  @unique
  // category: mood | theme | language | era | style
  category String  @default("theme")
  color    String? // hex color for UI badge

  poemTags PoemTag[]

  @@index([slug])
  @@index([category])
}

// ─── Poems ───────────────────────────────────────────────────────────────────

model Poem {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String   @db.Text   // Full poem text, newlines preserved
  excerpt     String?             // First 2–3 lines for cards
  authorId    String
  language    String   @default("en")
  // source: "classic" | "user-submitted" | "imported"
  source      String   @default("classic")
  // External URL if scraped
  sourceUrl   String?
  // Computed reading time in seconds
  readingTime Int?
  /// Approximate year the poem was written or first published (if known)
  writtenYear Int?
  /// Literary period or free-text date hint (e.g. "Victorian era", "Early 20th century")
  writtenPeriod String?
  /// Set after an automatic enrichment attempt (success or not) to avoid repeat API calls on every page view
  writtenDateEnrichedAt DateTime?
  /// Instagram carousel generator settings for this poem (theme, font, layout, CTA, keywords). Optional; when set, overrides site defaults for this poem only.
  carouselFontSettings Json?
  featured    Boolean  @default(false)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author    Author     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  poemTags  PoemTag[]
  favorites Favorite[]

  @@index([slug])
  @@index([authorId])
  @@index([language])
  @@index([featured])
  @@index([publishedAt])
}

// ─── Poem ↔ Tag (many-to-many) ───────────────────────────────────────────────

model PoemTag {
  poemId String
  tagId  String

  poem Poem @relation(fields: [poemId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([poemId, tagId])
}

// ─── Users ───────────────────────────────────────────────────────────────────

enum UserRole {
  user
  admin
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  name         String?
  role         UserRole   @default(user)
  /// Poem reader font key (see READER_FONT_STACKS in composables/useReaderPreferences.ts)
  poemFontFamily String   @default("playfair")
  /// Body font size in px (16–48)
  poemFontSize   Int      @default(22)
  /// Line height multiplier for poem body (e.g. 1.2–2.5)
  poemLineHeight Float    @default(1.2)
  /// Letter spacing in em (e.g. 0.02 = 0.02em)
  poemLetterSpacing Float @default(0.02)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  favorites Favorite[]

  @@index([email])
}

// ─── Favorites ───────────────────────────────────────────────────────────────

model Favorite {
  userId    String
  poemId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  poem Poem @relation(fields: [poemId], references: [id], onDelete: Cascade)

  @@id([userId, poemId])
  @@index([userId])
}

// ─── Admin Users ─────────────────────────────────────────────────────────────

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── Site carousel defaults (Instagram generator) ───────────────────────────

/// Single row: default theme & typography for `/carousel-generator` (editable only by configured admin email).
model CarouselSiteDefaults {
  id        String   @id @default("singleton")
  config    Json
  updatedAt DateTime @updatedAt
  updatedBy String?
}

// ─── Import Log ──────────────────────────────────────────────────────────────
// Track bulk import runs to prevent re-import and debug issues

model ImportLog {
  id         String   @id @default(cuid())
  source     String   // e.g. "poetrydb", "csv-upload"
  status     String   // "success" | "partial" | "failed"
  imported   Int      @default(0)
  skipped    Int      @default(0)
  errors     Int      @default(0)
  details    String?  @db.Text
  createdAt  DateTime @default(now())
}

// ─── Romanian lexicon (`/write` — dictionary search; import from rhymescheme) ─

model WriteLexiconWord {
  id            String   @id @default(cuid())
  word          String   @unique
  baseForm      String
  type          String
  syllables     String
  syllableCount Int
  endingKey     String
  endingLast    String
  definition    String?
  synonymsJson  String   @default("[]")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([endingKey])
  @@index([endingLast])
  @@index([type])
  @@index([syllableCount])
}

model WriteCachedLookup {
  id        String   @id @default(cuid())
  cacheKey  String   @unique
  source    String
  payload   String
  createdAt DateTime @default(now())
}
